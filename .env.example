# ---- Idea Forge backend configuration ----
# Copy to .env and fill in. Everything has a sane default; only TAVILY_API_KEY
# and CURSOR_API_KEY are needed for the full live experience.

PORT=8787
HOST=0.0.0.0

# Comma-separated seed topics the discovery pipeline starts from.
SEED_TOPICS=ai tools,developer productivity,indie saas,automation,no-code

# ---- Tavily (web/trend discovery) ---- REQUIRED for live web ideas
TAVILY_API_KEY=

# ---- Reddit ---- optional; public JSON API used when blank
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=idea-forge/0.1 (discovery bot)
REDDIT_SUBREDDITS=SaaS,SideProject,Entrepreneur,startups,webdev,AppIdeas

# ---- Anthropic ---- optional; heuristic fallback used when blank
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ---- Cursor (auto-build) ---- REQUIRED for real MVP builds
CURSOR_API_KEY=
CURSOR_ENABLED=true
BUILDS_DIR=.builds

# ---- Pipeline tuning ----
PER_SOURCE_LIMIT=25
WITHIN_HOURS=168
MAX_IDEAS=50

# ---- Scoring weights (sum ~1.0) ----
W_DEMAND=0.4
W_RECENCY=0.2
W_NOVELTY=0.2
W_FEASIBILITY=0.2
