{
  "name": "apptok-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AppTok — AI that discovers buildable app ideas from Tavily/Reddit/HN and auto-builds minimal MVPs via Cursor, served as a TikTok-style feed",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "discover": "tsx scripts/discover-cli.ts",
    "build:tsc": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.51",
    "@fastify/cors": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tavily/core": "^0.5.3",
    "ai": "^6.0.208",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "tavily-mcp": "^0.2.20",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
